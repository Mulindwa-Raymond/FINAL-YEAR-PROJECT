                        <td className="px-6 py-4 text-sm font-medium text-slate-700">{formatCurrencyUGX(eq.current_price_ugx)}</td>
                        <td className="px-6 py-4 text-sm text-slate-600">{formatCurrencyUGX(eq.estimated_tco_per_year_ugx)}</td>
