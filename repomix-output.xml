        {/* Search and Filter Bar */}
        <div className={`mb-8 flex flex-wrap items-center justify-between gap-4 transition-all duration-700 delay-100 ${fadeIn ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-5'}`}>
