              Compare categories <ArrowRight size={10} />
            </button>
          </p>
        </div>
      </main>

      {/* Subtype Selection Modal */}
      {showSubtypeModal && pendingCategory && (
        <SubtypeModal
          category={pendingCategory}
          onSelect={handleSubtypeConfirm}
