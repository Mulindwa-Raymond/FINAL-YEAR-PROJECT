                    ) : (
                      <p className="text-slate-600 text-sm">{userData.bio}</p>
                    )}
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* ======================= SETTINGS TAB ======================= */}
          {activeTab === 'settings' && (
            <div className="space-y-8">
