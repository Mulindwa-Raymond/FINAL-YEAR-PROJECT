                    </div>
                  </div>

                  {/* Question Body */}
                  <div className="p-6">
                    <DynamicFormField
                      field={currentField}
                      value={answers[currentField.id]}
                      onChange={handleFieldChange}
                      onBlur={() => handleFieldBlur(currentField.id)}
                      error={!!errors[currentField.id] && touched[currentField.id]}
