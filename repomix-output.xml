  const commonPasswords = ['admin123', 'admin', 'password', '123456', 'admin123!'];
  for (const testPass of commonPasswords) {
    const match = await bcrypt.compare(testPass, storedHash);
    console.log(`  "${testPass}": ${match}`);
  }
};

