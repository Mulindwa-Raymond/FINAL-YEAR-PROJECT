{
  "ignore": [
    "node_modules/",
    "uploads/",
    "logs/",
    ".git/",
    "tests/",
    "playwright-report/",
    "test-results/"
  ],
  "watch": [
    "server.js",
    "config/",
    "controllers/",
    "middleware/",
    "models/",
    "routes/",
    "services/",
    "utils/"
  ],
  "ext": "js",
  "delay": 500,
  "env": {
    "NODE_ENV": "development"
  }
}
