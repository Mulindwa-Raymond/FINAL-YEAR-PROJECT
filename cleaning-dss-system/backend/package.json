{
  "name": "clean-match-backend",
  "version": "1.0.0",
  "description": "Decision Support System for Cleaning Equipment and Detergents",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node utils/seedData.js",
    "seed-trainings": "node utils/seedTrainings.js",
    "seed-compatibility": "node utils/seedCompatibility.js",
    "test:unit": "cross-env NODE_ENV=test jest --testPathPatterns=unit",
    "test:integration": "cross-env NODE_ENV=test jest --testPathPatterns=integration",
    "test:system": "cross-env NODE_ENV=test jest --testPathPatterns=system",
    "test": "cross-env NODE_ENV=test jest",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "test:report": "node scripts/testReporter.js",
    "test:all": "npm run test && npm run test:report",
    "test:prod": "cross-env NODE_ENV=test TEST_ENV=production jest --testPathPatterns=integration"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.8.9",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "nodemailer": "^9.0.1",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@shelf/jest-mongodb": "^6.0.2",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "jest-extended": "^7.0.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
