{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "env": {
    "VITE_APP_API_URL": "https://clean-match.onrender.com/api/v1",
    "VITE_APP_TOKEN_KEY": "token",
    "VITE_APP_USER_KEY": "user",
    "VITE_APP_APP_NAME": "Clean Match DSS",
    "VITE_APP_ENABLE_REGISTRATION": "true",
    "VITE_APP_DEFAULT_PAGE_SIZE": "20",
    "VITE_APP_MAX_UPLOAD_SIZE_MB": "10",
    "VITE_APP_DEBUG": "false"
  }
}